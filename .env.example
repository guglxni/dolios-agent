# Dolios Agent — Environment Variables
# Copy to .env and fill in your API keys

# Inference Providers (at least one required)
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
NOUS_API_KEY=
OPENAI_API_KEY=

# Dolios Configuration
DOLIOS_LOG_LEVEL=INFO
DOLIOS_INFERENCE_PROVIDER=openrouter
# DOLIOS_INFERENCE_MODEL=
# DOLIOS_SANDBOX_DISABLED=1

# Messaging (optional)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
